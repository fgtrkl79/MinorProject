<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MinorProject.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MinorProject.Views.MainTable"
             x:DataType="vm:MainViewModel">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">

        <!-- Главный заголовок -->
        <TextBlock Text="Нагрузка на подстанцию"
                   FontSize="28"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30" />

        <Border BorderBrush="Black" BorderThickness="1" Width="850">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="70" /> <!-- Заголовок таблицы -->
                    <RowDefinition Height="60" /> <!-- Т1 -->
                    <RowDefinition Height="60" /> <!-- Т2 -->
                    <RowDefinition Height="60" /> <!-- Выход -->
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1.2*" /> 
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.Styles>
                    <Style Selector="Border.cell">
                        <Setter Property="BorderBrush" Value="Black" />
                        <Setter Property="BorderThickness" Value="1" />
                    </Style>
                    <Style Selector="TextBlock.cellText">
                        <Setter Property="HorizontalAlignment" Value="Center" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="TextAlignment" Value="Center" />
                        <Setter Property="FontSize" Value="15" />
                    </Style>
                </Grid.Styles>

                <!-- ================= СТРОКА 0: ЗАГОЛОВКИ ================= -->
                <!-- Обратите внимание: добавлен Background="#E8E8E8" для шапки -->
                <Border Grid.Row="0" Grid.Column="0" Classes="cell" Background="#E8E8E8">
                    <TextBlock Text="Наименование" Classes="cellText" FontWeight="Bold"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Classes="cell" Background="#E8E8E8">
                    <TextBlock Text="Напряжение" Classes="cellText" FontWeight="Bold"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="2" Classes="cell" Background="#E8E8E8">
                    <TextBlock Text="Температура&#x0a;масла" Classes="cellText" FontWeight="Bold"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="3" Classes="cell" Background="#E8E8E8">
                    <TextBlock Text="Давление" Classes="cellText" FontWeight="Bold"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="4" Classes="cell" Background="#E8E8E8">
                    <TextBlock Text="Мощность" Classes="cellText" FontWeight="Bold"/>
                </Border>

                <!-- ================= СТРОКА 1: Т1 ================= -->
                <Border Grid.Row="1" Grid.Column="0" Classes="cell">
                    <TextBlock Text="Т1" Classes="cellText" FontWeight="SemiBold"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Classes="cell">
                    <TextBlock Text="{Binding T1.Voltage}" Classes="cellText"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="2" Classes="cell" >
                    <TextBlock Text="{Binding T1.OilTemperature}" Classes="cellText"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="3" Classes="cell" >
                    <TextBlock Text="{Binding T1.Pressure}" Classes="cellText"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="4" Classes="cell" >
                    <TextBlock Text="{Binding T1.Power}" Classes="cellText"/>
                </Border>

                <!-- ================= СТРОКА 2: Т2 ================= -->
                <Border Grid.Row="2" Grid.Column="0" Classes="cell">
                    <TextBlock Text="Т2" Classes="cellText" FontWeight="SemiBold"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="1" Classes="cell">
                    <TextBlock Text="{Binding T2.Voltage}" Classes="cellText"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="2" Classes="cell">
                    <TextBlock Text="{Binding T2.OilTemperature}" Classes="cellText"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="3" Classes="cell">
                    <TextBlock Text="{Binding T2.Pressure}" Classes="cellText"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="4" Classes="cell">
                    <TextBlock Text="{Binding T2.Power}" Classes="cellText"/>
                </Border>

                <!-- ================= СТРОКА 3: Выход ================= -->
                <Border Grid.Row="3" Grid.Column="0" Classes="cell" Background="#F9F9F9">
                    <TextBlock Text="Выход" Classes="cellText" FontWeight="SemiBold"/>
                </Border>
                <Border Grid.Row="3" Grid.Column="1" Classes="cell" Background="#F9F9F9"/>
                <Border Grid.Row="3" Grid.Column="2" Classes="cell" Background="#F9F9F9"/>
                <Border Grid.Row="3" Grid.Column="3" Classes="cell" Background="#F9F9F9"/>
                <!-- Ячейка "Мощность на выходе" (Если в MainViewModel есть свойство TotalPower) -->
                <Border Grid.Row="3" Grid.Column="4" Classes="cell" Background="#F9F9F9">
                     <TextBlock Text="—" Classes="cellText" Foreground="Gray"/>
                </Border>

            </Grid>
        </Border>
    </StackPanel>
</UserControl>