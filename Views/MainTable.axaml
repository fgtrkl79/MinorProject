<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MinorProject.ViewModels"
             xmlns:models="clr-namespace:MinorProject.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
             x:Class="MinorProject.Views.MainTable"
             x:DataType="vm:MainViewModel">

    <ScrollViewer>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">

            <TextBlock Text="Нагрузка на подстанцию"
                       FontSize="28"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20" />

            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="20"
                    Margin="0,0,0,20"
                    Width="1040"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                <StackPanel>
                    <TextBlock Text="Потребители"
                               FontSize="18"
                               FontWeight="Bold" />

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,10">
                        <TextBlock Text="Суммарный запрос: " FontSize="14" />
                        <TextBlock Text="{Binding TotalDemand, StringFormat='{}{0:F1} МВА'}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="DodgerBlue" />
                        <TextBlock Text="  |  К распределению: " FontSize="14" Margin="18,0,0,0" />
                        <TextBlock Text="{Binding EffectiveDemand, StringFormat='{}{0:F1} МВА'}"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="OrangeRed" />
                    </StackPanel>

                    <TextBlock Text="{Binding DemandWarning}"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="IndianRed"
                               Margin="0,0,0,12"
                               IsVisible="{Binding DemandWarning, Converter={x:Static vm:StringNotEmptyConverter.Instance}}" />

                    <ItemsControl ItemsSource="{Binding Consumers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="320" ItemHeight="260" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ConsumerModel">
                                <Border Margin="0,0,20,20"
                                        Padding="16"
                                        Width="300"
                                        Height="240"
                                        CornerRadius="8"
                                        BorderThickness="2"
                                        BorderBrush="{Binding CardBorderBrush}"
                                        Background="{DynamicResource SystemControlBackgroundAltMediumLowBrush}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center" />

                                        <Border Margin="0,12,0,10"
                                                Height="44"
                                                CornerRadius="4"
                                                Background="{Binding StatusBackgroundBrush}"
                                                BorderThickness="2"
                                                BorderBrush="{Binding CardBorderBrush}">
                                            <TextBlock Text="{Binding StatusText}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding StatusBrush}" />
                                        </Border>

                                        <TextBlock Text="{Binding RequestedPower, StringFormat='Требуемая мощность: {0:F0} МВА'}"
                                                   FontSize="13"
                                                   HorizontalAlignment="Center" />

                                        <Slider Minimum="0"
                                                Maximum="80"
                                                Value="{Binding RequestedPower}"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                Margin="0,8,0,12" />

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="{Binding PowerButtonText}"
                                                    Command="{Binding TogglePowerCommand}"
                                                    Width="115"
                                                    Margin="0,0,8,0"
                                                    CornerRadius="4" />
                                            <Button Content="{Binding RepairButtonText}"
                                                    Command="{Binding ToggleBrokenCommand}"
                                                    Width="115"
                                                    CornerRadius="4" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="20"
                    Margin="0,0,0,20"
                    Width="1040"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                <StackPanel>
                    <TextBlock Text="Настройки распределения" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />

                    <TextBlock Text="Стратегия распределения" FontSize="13" Margin="0,0,0,5" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="Т1 -> Т2 (приоритет Т1)"
                                Command="{Binding SetStrategyT1FirstCommand}"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                FontSize="12"
                                CornerRadius="4"
                                Background="{DynamicResource SystemControlHighlightAccentBrush}"
                                Foreground="White" />
                        <Button Content="Т2 -> Т1 (приоритет Т2)"
                                Command="{Binding SetStrategyT2FirstCommand}"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                FontSize="12"
                                CornerRadius="4" />
                        <Button Content="Пропорционально"
                                Command="{Binding SetStrategyProportionalCommand}"
                                Padding="12,6"
                                FontSize="12"
                                CornerRadius="4" />
                    </StackPanel>

                    <TextBlock Text="{Binding StrategyText}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="DodgerBlue"
                               Margin="0,0,0,10" />

                    <TextBlock Text="{Binding BalancerSettingsError}"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="IndianRed"
                               Margin="0,0,0,5"
                               IsVisible="{Binding BalancerSettingsError, Converter={x:Static vm:StringNotEmptyConverter.Instance}}" />
                    <TextBlock Text="{Binding BalancerSettingsSuccess}"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="LimeGreen"
                               Margin="0,0,0,5"
                               IsVisible="{Binding BalancerSettingsSuccess, Converter={x:Static vm:StringNotEmptyConverter.Instance}}" />

                    <Grid ColumnDefinitions="260, 110, 30, 260, 110" RowDefinitions="Auto, 10, Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Лимит Т1 в балансировщике (МВА):"
                                   VerticalAlignment="Center"
                                   FontSize="13" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditBalancerMaxT1}" FontSize="13" />

                        <TextBlock Grid.Row="0" Grid.Column="3"
                                   Text="Лимит Т2 в балансировщике (МВА):"
                                   VerticalAlignment="Center"
                                   FontSize="13" />
                        <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding EditBalancerMaxT2}" FontSize="13" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Порог подключения Т2 (МВА):"
                                   VerticalAlignment="Center"
                                   FontSize="13" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditT2Threshold}" FontSize="13" />

                        <TextBlock Grid.Row="2" Grid.Column="3"
                                   Text="Макс. потребление подстанции (МВА):"
                                   VerticalAlignment="Center"
                                   FontSize="13" />
                        <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding EditMaxTotalDemand}" FontSize="13" />
                    </Grid>

                    <Button Content="Применить настройки"
                            Command="{Binding ApplyBalancerSettingsCommand}"
                            Padding="16,8"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Left"
                            CornerRadius="4"
                            Background="#2196F3"
                            Foreground="White"
                            FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Width="1040">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="70" />
                        <RowDefinition Height="60" />
                        <RowDefinition Height="60" />
                        <RowDefinition Height="60" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.Styles>
                        <Style Selector="Border.cell">
                            <Setter Property="BorderBrush"
                                    Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                        </Style>
                        <Style Selector="TextBlock.cellText">
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="TextAlignment" Value="Center" />
                            <Setter Property="FontSize" Value="15" />
                        </Style>
                    </Grid.Styles>

                    <Border Grid.Row="0" Grid.Column="0" Classes="cell"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                        <TextBlock Text="Наименование" Classes="cellText" FontWeight="Bold" />
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" Classes="cell"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                        <TextBlock Text="Статус" Classes="cellText" FontWeight="Bold" />
                    </Border>
                    <Border Grid.Row="0" Grid.Column="2" Classes="cell"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                        <TextBlock Text="Напряжение" Classes="cellText" FontWeight="Bold" />
                    </Border>
                    <Border Grid.Row="0" Grid.Column="3" Classes="cell"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                        <TextBlock Text="Температура&#x0a;масла" Classes="cellText" FontWeight="Bold" />
                    </Border>
                    <Border Grid.Row="0" Grid.Column="4" Classes="cell"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                        <TextBlock Text="Давление" Classes="cellText" FontWeight="Bold" />
                    </Border>
                    <Border Grid.Row="0" Grid.Column="5" Classes="cell"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                        <TextBlock Text="Мощность" Classes="cellText" FontWeight="Bold" />
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Classes="cell">
                        <TextBlock Text="Т1" Classes="cellText" FontWeight="SemiBold" />
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Classes="cell">
                        <TextBlock Text="{Binding T1StatusIcon}"
                                   FontSize="20"
                                   Foreground="{Binding T1StatusBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <Border Grid.Row="1" Grid.Column="2" Classes="cell">
                        <TextBlock Text="{Binding T1.Voltage}" Classes="cellText" />
                    </Border>
                    <Border Grid.Row="1" Grid.Column="3" Classes="cell">
                        <TextBlock Text="{Binding T1.OilTemperature}" Classes="cellText" />
                    </Border>
                    <Border Grid.Row="1" Grid.Column="4" Classes="cell">
                        <TextBlock Text="{Binding T1.Pressure}" Classes="cellText" />
                    </Border>
                    <Border Grid.Row="1" Grid.Column="5" Classes="cell">
                        <TextBlock Text="{Binding T1.Power}" Classes="cellText" />
                    </Border>

                    <Border Grid.Row="2" Grid.Column="0" Classes="cell">
                        <TextBlock Text="Т2" Classes="cellText" FontWeight="SemiBold" />
                    </Border>
                    <Border Grid.Row="2" Grid.Column="1" Classes="cell">
                        <TextBlock Text="{Binding T2StatusIcon}"
                                   FontSize="20"
                                   Foreground="{Binding T2StatusBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <Border Grid.Row="2" Grid.Column="2" Classes="cell">
                        <TextBlock Text="{Binding T2.Voltage}" Classes="cellText" />
                    </Border>
                    <Border Grid.Row="2" Grid.Column="3" Classes="cell">
                        <TextBlock Text="{Binding T2.OilTemperature}" Classes="cellText" />
                    </Border>
                    <Border Grid.Row="2" Grid.Column="4" Classes="cell">
                        <TextBlock Text="{Binding T2.Pressure}" Classes="cellText" />
                    </Border>
                    <Border Grid.Row="2" Grid.Column="5" Classes="cell">
                        <TextBlock Text="{Binding T2.Power}" Classes="cellText" />
                    </Border>

                    <Border Grid.Row="3" Grid.Column="0" Classes="cell"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                        <TextBlock Text="Выход (сумма)" Classes="cellText" FontWeight="SemiBold" />
                    </Border>
                    <Border Grid.Row="3" Grid.Column="1" Classes="cell"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
                    <Border Grid.Row="3" Grid.Column="2" Classes="cell"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
                    <Border Grid.Row="3" Grid.Column="3" Classes="cell"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                        <TextBlock Text="{Binding AvgTemperature}"
                                   Classes="cellText"
                                   FontWeight="Bold"
                                   Foreground="DodgerBlue" />
                    </Border>
                    <Border Grid.Row="3" Grid.Column="4" Classes="cell"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
                    <Border Grid.Row="3" Grid.Column="5" Classes="cell"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                        <TextBlock Text="{Binding TotalPower}"
                                   Classes="cellText"
                                   FontWeight="Bold"
                                   Foreground="DodgerBlue" />
                    </Border>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
