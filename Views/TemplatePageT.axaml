<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:vm="clr-namespace:MinorProject.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:avalonia="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MinorProject.Views.TemplatePageT" x:DataType="vm:TemplatePageTViewModel">
    <Grid RowDefinitions="Auto, *">
        <TextBlock Grid.Row="0"
                   Text="Информация"
                   FontSize="28"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>
        
        <Grid Grid.Row="1" ColumnDefinitions="*, Auto, *">
            <Grid Grid.Column="0" RowDefinitions="*, 20, *">
                
                <!-- Заглушка для Графика 1 (Верхний левый) -->
                <!-- ЗАМЕНИ BORDER НА СВОЙ КОНТРОЛ ГРАФИКА, например <lvc:CartesianChart Series="{Binding Chart1Series}" /> -->
                <Border Grid.Row="0" BorderBrush="Black" BorderThickness="1" Background="White">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <!-- подпись графика -->
                        <TextBlock Grid.Row="0" Text="{Binding ChartTitle1}"
                                   HorizontalAlignment="Center"
                                   Margin="5" FontSize="14"
                                   Foreground="Black"/>
                        <avalonia:CartesianChart Grid.Row="1"
                            Series="{Binding Chart1Series}" 
                            TooltipPosition="Hidden" 
                            Margin="10"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch" />
                    </Grid>
                </Border>

                <!-- Заглушка для Графика 2 (Нижний левый) -->
                <Border Grid.Row="2" BorderBrush="Black" BorderThickness="1" Background="White">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <!-- подпись графика -->
                        <TextBlock Grid.Row="0" Text="{Binding ChartTitle2}"
                                   HorizontalAlignment="Center"
                                   Margin="5" FontSize="14"
                                   Foreground="Black"/>
                        <avalonia:CartesianChart Grid.Row="1"
                            Series="{Binding Chart2Series}" 
                            TooltipPosition="Hidden" 
                            Margin="10"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch" />
                    </Grid>
                </Border>
            </Grid>
            
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="30,0">
                <TextBlock Text="ситуации" HorizontalAlignment="Center" Margin="0,0,0,10" FontSize="14"/>
                
                <StackPanel.Styles>
                    <!-- Стилизуем кнопки как на картинке: прозрачный фон, черная рамка -->
                    <Style Selector="Button.situation">
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Black"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Margin" Value="0,0,0,15"/>
                        <Setter Property="Padding" Value="15,8"/>
                        <Setter Property="CornerRadius" Value="0"/> <!-- Острые углы -->
                    </Style>
                </StackPanel.Styles>

                <!-- Кнопки биндятся на команды (Command) из ViewModel -->
                <Button Classes="situation" Command="{Binding PowerChangeCommand}">
                    <TextBlock Text="Изменение мощности&#x0a;потребителей" TextAlignment="Center"/>
                </Button>
                
                <Button Classes="situation" Content="Вкл/выкл (Системы)" Command="{Binding ToggleSystemCommand}"/>
                
                <Button Classes="situation" Command="{Binding ShortCircuitCommand}">
                    <TextBlock Text="КЗ (Трансформатор,&#x0a;потребители)" TextAlignment="Center"/>
                </Button>
                
                <Button Classes="situation" Command="{Binding LeakCommand}">
                    <TextBlock Text="Протечка системы&#x0a;охлаждения" TextAlignment="Center"/>
                </Button>
                
                <Button Classes="situation" Command="{Binding FanFailureCommand}">
                    <TextBlock Text="Выход из строя&#x0a;вентилятора" TextAlignment="Center"/>
                </Button>
                
                <Button
                    Command="{Binding DoRandomChangeCommand}"
                    Content="Change value"/>
            </StackPanel>
            
            <Grid Grid.Column="2" RowDefinitions="*, 20, *">
                
                <!-- Заглушка для Графика 3 (Верхний правый) -->
                <Border Grid.Row="0" BorderBrush="Black" BorderThickness="1">
                    <avalonia:PieChart
                        InitialRotation="-225"
                        MaxAngle="270"
                        MinValue="0"
                        MaxValue="100">

                        <avalonia:PieChart.Series>

                            <avalonia:XamlAngularGaugeSeries
                                GaugeValue="60"
                                OuterRadiusOffset="130"
                                MaxRadialColumnWidth="20"
                                CornerRadius="0"/>

                            <avalonia:XamlAngularGaugeSeries
                                GaugeValue="30"
                                OuterRadiusOffset="130"
                                MaxRadialColumnWidth="20"
                                CornerRadius="0"/>

                            <avalonia:XamlAngularGaugeSeries
                                GaugeValue="10"
                                OuterRadiusOffset="130"
                                MaxRadialColumnWidth="20"
                                CornerRadius="0"/>
                        </avalonia:PieChart.Series>

                        <avalonia:PieChart.VisualElements>

                            <avalonia:XamlNeedle
                                Width="20"
                                Value="{Binding Value}"/>

                            <avalonia:XamlAngularTicks
                                LabelsSize="16"
                                LabelsOuterOffset="15"
                                OuterOffset="65"
                                TicksLength="20" />

                        </avalonia:PieChart.VisualElements>

                    </avalonia:PieChart>
                </Border>

                <!-- Заглушка для Графика 4 (Нижний правый) -->
                <Border Grid.Row="2" BorderBrush="Black" BorderThickness="1">
                    <TextBlock Text="[ Место для Графика 4 ]" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>
                </Border>
            </Grid>
            
        </Grid>
    </Grid>
</UserControl>
